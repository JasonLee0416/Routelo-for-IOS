{
  "expo": {
    "name": "Routelo",
    "slug": "routelo-for-ios",
    "scheme": "routeloforios",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jasonlee0312.routelo.ios",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "배송 영수증 촬영·인식과 배송 완료 사진 첨부를 위해 카메라를 사용합니다.",
        "NSPhotoLibraryUsageDescription": "저장된 배송 영수증 선택·인식과 배송 완료 사진 첨부를 위해 사진 보관함을 사용합니다.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          }
        ]
      }
    },
    "android": {
      "package": "com.jasonlee0312.routelo",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "onnxruntime-react-native"
    ],
    "extra": {
      "eas": {
        "projectId": "1e61d1e8-ac25-41bc-b832-09f858aff8b9"
      }
    },
    "owner": "jasonlee0312"
  }
}
