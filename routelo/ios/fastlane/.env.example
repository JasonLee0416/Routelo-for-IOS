# 이 파일을 복사해 `ios/fastlane/.env` 로 만들고 값을 채운다(.env는 git 미추적).
# App Store Connect API 키 방식(권장) — 2FA 없이 헤드리스 업로드 가능.

# App Store Connect > Users and Access > Integrations 에서 발급
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 다운로드한 AuthKey_XXXXXXXXXX.p8 파일 경로(레포 밖에 두는 것을 권장)
ASC_KEY_PATH=/절대/경로/AuthKey_XXXXXXXXXX.p8

# 10자리 Apple 팀 ID(자동 서명용). Xcode 계정 또는 developer.apple.com에서 확인.
DEVELOPMENT_TEAM=XXXXXXXXXX

# 최종 번들 ID가 기본값과 다르면 지정.
# PRODUCT_BUNDLE_IDENTIFIER=com.jasonlee0312.routelo.ios
