{
  "name": "routelo-for-ios",
  "version": "1.0.0",
  "main": "index.js",
  "dependencies": {
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/blur": "^4.4.1",
    "base64-js": "^1.5.1",
    "jpeg-js": "^0.4.4",
    "onnxruntime-react-native": "^1.24.3",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-fs": "^2.20.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-permissions": "^5.4.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-vector-icons": "^10.3.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.0.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/jest-preset": "^0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.2",
    "@types/react-native-vector-icons": "^6.4.18",
    "jest": "^29.7.0",
    "onnxruntime-node": "^1.27.0",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "react-native start",
    "ios": "react-native run-ios",
    "build:ios:device": "sh scripts/build-ios-device.sh",
    "cleanup:device-test": "node scripts/cleanup-device-test.mjs",
    "test": "jest",
    "test:ci": "jest --runInBand",
    "verify:ocr-models": "node scripts/verify-ocr-models.mjs",
    "verify:no-mlkit": "node scripts/verify-no-mlkit.mjs",
    "typecheck": "tsc --noEmit",
    "validate": "npm run verify:no-mlkit && npm run verify:ocr-models && npm run test:ci && npm run typecheck",
    "postinstall": "patch-package"
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "testMatch": [
      "**/__tests__/**/*.test.ts?(x)"
    ]
  },
  "private": true
}
